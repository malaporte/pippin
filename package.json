{
  "name": "pippin",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "pippin": "src/cli/index.ts"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:server": "bun run scripts/build.ts --server",
    "build:cli": "bun run scripts/build.ts --cli",
    "deploy:cli": "bun run scripts/deploy-cli.ts",
    "pippin": "bun run src/cli/index.ts",
    "shell": "PATH=$(pwd)/scripts:$PATH $SHELL",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx --bun vitest run"
  },
  "dependencies": {
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "bun-types": "^1.2.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
